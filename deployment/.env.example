# --- The Hub: Supabase (Managed Relational State) ---
# Format: postgresql://postgres.xxxxxx:password@aws-0-xx-xxxx-x.pooler.supabase.com:6543/postgres
DATABASE_URL=your_supabase_connection_string_here

# --- Object Storage (MinIO) ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=generate_secure_password_here

# --- External AI Services ---
OLLAMA_BASE_URL=http://worker-vps-ip:11434
VAST_API_KEY=your_vast_ai_api_key_here

# --- Security ---
SECRET_KEY=generate_a_long_random_secret_here
ALLOWED_ORIGINS=http://your-dashboard-domain.com,http://localhost:3000
